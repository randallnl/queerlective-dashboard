---
import Calendar from "../components/Calendar.svelte";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CoLab Member Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="is-app-loading">
    <section class="splash-screen" id="app-splash" aria-live="polite">
      <div class="splash-card">
        <span class="brand-mark splash-mark">Q</span>
        <p class="eyebrow" id="splash-kicker">CoLab member portal</p>
        <h1 id="splash-title">Checking your login</h1>
        <p id="splash-copy">
          We are getting your member dashboard ready before showing the workspace.
        </p>
        <form class="login-form splash-login-form is-hidden" id="splash-login-form">
          <label for="splash-login-email">Member email</label>
          <div>
            <input
              id="splash-login-email"
              name="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              required
            />
            <button type="submit">Send link</button>
          </div>
          <small id="splash-login-note">Use the email on your CoLab member profile.</small>
        </form>
      </div>
    </section>
    <div class="app-shell">
      <aside class="sidebar" aria-label="Main navigation">
        <a class="brand" href="#overview" aria-label="CoLab member portal">
          <span class="brand-mark">Q</span>
          <span>
            <strong>CoLab</strong>
            <small>Member Portal</small>
          </span>
        </a>
        <nav class="nav-list">
          <a href="#overview" class="active" data-section-link="overview">
            <span>Overview</span>
          </a>
          <a href="#shifts" id="nav-shifts" data-section-link="shifts">
            <span>Shifts</span>
          </a>
          <a href="#calendar" data-section-link="calendar">
            <span>Calendar</span>
          </a>
          <a href="#announcements" data-section-link="announcements">
            <span>Votes</span>
          </a>
          <a href="#activity" data-section-link="activity">
            <span>Activity</span>
          </a>
          <a href="#payments" data-section-link="payments">
            <span>Dues</span>
          </a>
          <a href="#orders" id="nav-orders" data-section-link="orders">
            <span>Orders</span>
          </a>
          <a href="#resources" data-section-link="resources">
            <span>Resources</span>
          </a>
          <a
            href="#project-management"
            id="nav-project-management"
            class="is-hidden"
            data-section-link="project-management"
          >
            <span>Admin Projects</span>
          </a>
        </nav>
        <div class="member-card">
          <span class="avatar" id="member-avatar">--</span>
          <div>
            <strong id="sidebar-member-name">Loading member</strong>
            <small id="sidebar-member-detail">CoLab member</small>
          </div>
        </div>
      </aside>

      <main>
        <header class="topbar">
          <div>
            <p class="eyebrow">Wednesday, July 1</p>
            <h1 id="welcome-heading">Welcome back</h1>
          </div>
          <div class="topbar-actions">
            <div class="access-card" aria-live="polite">
              <span id="access-status">Checking login</span>
              <strong id="access-email">Magic link login</strong>
              <form class="login-form is-hidden" id="login-form">
                <label for="login-email">Member email</label>
                <div>
                  <input
                    id="login-email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    placeholder="you@example.com"
                    required
                  />
                  <button type="submit">Send link</button>
                </div>
                <small id="login-note">Use the email on your CoLab member profile.</small>
              </form>
              <a id="access-logout" href="/api/auth/logout">Log out</a>
            </div>
            <label class="compact-field" id="member-select-field" for="member-select">
              View as
              <select id="member-select" aria-label="View dashboard as member">
                <option>Loading members</option>
              </select>
            </label>
            <button
              class="primary-action"
              id="header-shift-action"
              type="button"
              data-open-shift-modal
            >
              Sign up for a shift
            </button>
          </div>
        </header>

        <section class="hero" id="overview" aria-labelledby="overview-title">
          <img src="/assets/colab-studio-banner.jpg" alt="" />
          <div class="hero-copy">
            <p class="eyebrow">CoLab shared studio</p>
            <h2 id="overview-title">Your month at a glance</h2>
            <p>
              Keep track of studio commitments, upcoming events, community
              decisions, and dues in one member-friendly place.
            </p>
          </div>
        </section>

        <section class="metric-grid" aria-label="Member summary">
          <article id="next-shift-card">
            <span class="metric-label">Next shift</span>
            <strong id="next-shift">Loading</strong>
            <small>Open studio host</small>
          </article>
          <article>
            <span class="metric-label">Membership type</span>
            <strong id="membership-type">Loading</strong>
            <small id="member-email">Member profile</small>
          </article>
          <a class="metric-card metric-link" href="#announcements">
            <span class="metric-label">Votes open</span>
            <strong id="vote-count">0</strong>
            <small>Community decisions</small>
          </a>
          <a class="metric-card metric-link" href="#activity">
            <span class="metric-label">Activity this month</span>
            <strong id="activity-count">0</strong>
            <small id="activity-latest">Loading activity</small>
          </a>
        </section>

        <section class="full-width-stack">
          <section
            class="panel"
            id="shifts"
            aria-labelledby="shifts-title"
          >
            <div class="section-heading">
              <div>
                <p class="eyebrow">Studio coverage</p>
                <h2 id="shifts-title">Available shifts</h2>
              </div>
              <div class="panel-actions">
                <select id="shift-window" aria-label="Filter available shifts">
                  <option value="six-weeks">Next 6 weeks</option>
                  <option value="this-month">This month</option>
                  <option value="next-month">Next month</option>
                </select>
                <button class="secondary-action" type="button" data-open-shift-modal>
                  See all
                </button>
              </div>
            </div>
            <div class="shift-list" id="shift-list"></div>
          </section>

          <section class="panel" id="calendar" aria-labelledby="calendar-title">
            <div class="section-heading">
              <div>
                <p class="eyebrow">What is happening</p>
                <h2 id="calendar-title">Calendar</h2>
              </div>
              <div class="panel-actions">
                <a
                  class="secondary-action link-action"
                  href="https://wkf.ms/4aSHDGu"
                  target="_blank"
                  rel="noreferrer"
                >
                  Submit event
                </a>
              </div>
            </div>
            <Calendar client:load />
          </section>
        </section>

        <section class="full-width-stack">
          <section
            class="panel"
            id="announcements"
            aria-labelledby="announcements-title"
          >
            <div class="section-heading">
              <div>
                <p class="eyebrow">Community decisions</p>
                <h2 id="announcements-title">Announcements + votes</h2>
              </div>
            </div>
            <div class="announcement-list" id="announcement-list"></div>
          </section>

          <section class="panel" id="activity" aria-labelledby="activity-title">
            <div class="section-heading">
              <div>
                <p class="eyebrow">Member activity</p>
                <h2 id="activity-title">Activity summary</h2>
              </div>
              <span class="status-pill" id="activity-source">Loading</span>
            </div>
            <div class="activity-breakdown" id="activity-breakdown"></div>
            <div class="activity-list" id="activity-list"></div>
          </section>
        </section>

        <section class="full-width-stack">

          <section class="panel" id="payments" aria-labelledby="payments-title">
            <div class="section-heading">
              <div>
                <p class="eyebrow">Membership</p>
                <h2 id="payments-title">Payment history</h2>
              </div>
            </div>
            <div class="payment-list" id="payment-list"></div>
          </section>

          <section class="panel" id="orders" aria-labelledby="orders-title">
            <div class="section-heading">
              <div>
                <p class="eyebrow">Shopify support</p>
                <h2 id="orders-title">Open orders</h2>
              </div>
              <div class="panel-actions">
                <a
                  class="secondary-action link-action"
                  href="https://admin.shopify.com/store/queerlective/orders"
                  target="_blank"
                  rel="noreferrer"
                >
                  Fulfill orders
                </a>
                <span class="status-pill" id="order-count">Loading</span>
              </div>
            </div>
            <div class="order-list" id="order-list"></div>
          </section>
        </section>

        <section class="panel resources-panel" id="resources">
          <div class="section-heading">
            <div>
              <p class="eyebrow">Need something</p>
              <h2>Member resources</h2>
            </div>
          </div>
          <div class="resource-grid">
            <a
              href="https://queerlective.com/pages/colab-inventory"
              class="resource-link"
              target="_blank"
              rel="noreferrer"
            >
              <strong>CoLab Inventory</strong>
              <span>Browse shared tools, equipment, and studio resources.</span>
            </a>
            <a
              href="https://docs.google.com/document/d/1y2HjvNbVYdjXcpQjcL64vohjYI5RhZtB-X6oLXYqPr8/edit?usp=sharing"
              class="resource-link"
              target="_blank"
              rel="noreferrer"
            >
              <strong>CoLab Guidelines</strong>
              <span>Access shared expectations and safety notes.</span>
            </a>
            <div class="resource-link resource-note">
              <strong>Questions</strong>
              <span>Reach out to Randall@queerlective.com or awheeler@queerlective.com.</span>
            </div>
            <a href="https://wkf.ms/4aSHDGu" class="resource-link" target="_blank" rel="noreferrer">
              <strong>Submit an event</strong>
              <span>Propose a community-led event for CoLab support.</span>
            </a>
          </div>
        </section>

        <section
          class="panel admin-panel is-hidden"
          id="project-management"
          aria-labelledby="project-management-title"
        >
          <div class="section-heading">
            <div>
              <p class="eyebrow">Admin tools</p>
              <h2 id="project-management-title">Project management</h2>
            </div>
            <div class="panel-actions">
              <button class="secondary-action" type="button" id="project-sync-button">
                Sync D1
              </button>
              <span class="status-pill" id="project-management-count">Loading</span>
            </div>
          </div>
          <div class="admin-filters" aria-label="Project filters">
            <label class="compact-field" for="project-source-filter">
              Source
              <select id="project-source-filter">
                <option value="all">All sources</option>
                <option value="project">Project board</option>
                <option value="community">Community-led</option>
              </select>
            </label>
            <label class="compact-field" for="project-status-filter">
              Status
              <select id="project-status-filter">
                <option value="all">All statuses</option>
              </select>
            </label>
            <label class="compact-field" for="project-search">
              Search
              <input id="project-search" type="search" placeholder="Project, owner, location" />
            </label>
          </div>
          <div class="admin-project-list" id="admin-project-list"></div>
        </section>
      </main>
    </div>

    <dialog id="shift-modal">
      <form method="dialog" class="modal-card">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Shift signup</p>
            <h2>Choose a studio shift</h2>
          </div>
          <button class="icon-button" type="submit" aria-label="Close">×</button>
        </div>
        <label class="field-label" for="member-id-input">
          Member ID
          <input
            id="member-id-input"
            name="memberId"
            autocomplete="off"
            placeholder="Enter your CoLab member ID"
            readonly
          />
        </label>
        <p class="form-note" id="shift-source-note"></p>
        <div id="modal-shift-list" class="modal-shift-list"></div>
      </form>
    </dialog>

    <script src="/app.js" is:inline></script>
  </body>
</html>
